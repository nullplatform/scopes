#!/bin/bash
# =============================================================================
# Delete Parameter from Azure Key Vault
# =============================================================================
# Soft-deletes the Key Vault secret identified by EXTERNAL_ID. Treats a
# missing secret as success so retries are idempotent.
#
# Required env vars:
#   AZURE_KEY_VAULT_NAME - target Key Vault name
#   EXTERNAL_ID          - Key Vault secret name produced by `store`
# =============================================================================

set -euo pipefail

if [[ -z "${AZURE_KEY_VAULT_NAME:-}" ]]; then
  echo "ERROR: AZURE_KEY_VAULT_NAME must be set" >&2
  exit 1
fi

if [[ -z "${EXTERNAL_ID:-}" ]]; then
  echo '{ "success": true }'
  exit 0
fi

if ! az keyvault secret delete \
  --vault-name "$AZURE_KEY_VAULT_NAME" \
  --name "$EXTERNAL_ID" \
  --output none 2>/tmp/kv_del_err; then
  if ! grep -qi 'SecretNotFound\|not found\|was not found' /tmp/kv_del_err; then
    echo "ERROR: az keyvault secret delete failed for ${EXTERNAL_ID}" >&2
    cat /tmp/kv_del_err >&2 || true
    exit 1
  fi
fi

echo '{
  "success": true
}'
