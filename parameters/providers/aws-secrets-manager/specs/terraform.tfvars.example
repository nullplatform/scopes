nrn        = "organization=1"
np_api_key = "REPLACE_ME"

extra_visible_to_nrns = []

instances = {
  prod-billing = {
    nrn        = "organization=1:account=2:namespace=3"
    dimensions = { environment = "production" }
    kms_key_id = "alias/parameters-prod-billing"
    applies_to = ["secret"]

    # Each instance gets its own agent API key + notification channel anchored at its nrn.
    tags_selectors = { environment = "production" }
  }
  staging-billing = {
    nrn        = "organization=1:account=2:namespace=3"
    dimensions = { environment = "staging" }
    kms_key_id = ""
    applies_to = ["secret"]

    # Skip the agent channel + API key for this instance (e.g. managed elsewhere).
    notification_channel_enabled = false
  }
}

iam_role = {
  enable             = true
  name               = "nullplatform-secrets-manager"
  mode               = "default"
  trusted_principals = ["arn:aws:iam::688720756067:role/nullplatform-agent"]
}
