#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if ! type -t log >/dev/null 2>&1; then source "$SCRIPT_DIR/../logging"; fi

# audit-scope.sh
NAMESPACE="$K8S_NAMESPACE"

if [ -z "$SCOPE_ID" ]; then
    log error "Usage: $0 <scope_id> [namespace]"
    log error "Example: $0 1183007763 nullplatform"
    exit 1
fi

log debug "Auditing resources for scope $SCOPE_ID in namespace $NAMESPACE..."
log debug "----------------------------------------"

# Check Deployments
log debug "Checking Deployments:"
DEPLOYMENTS=$(kubectl get deployments -n $NAMESPACE | grep $SCOPE_ID)
DEPLOYMENT_COUNT=$(echo "$DEPLOYMENTS" | grep -v "^$" | wc -l)
log debug "$DEPLOYMENTS"
log debug "Found $DEPLOYMENT_COUNT deployment(s)"
log debug "----------------------------------------"

# Check Services
log debug "Checking Services:"
SERVICES=$(kubectl get services -n $NAMESPACE | grep $SCOPE_ID)
SERVICE_COUNT=$(echo "$SERVICES" | grep -v "^$" | wc -l)
log debug "$SERVICES"
log debug "Found $SERVICE_COUNT service(s)"
log debug "----------------------------------------"

# Check ReplicaSets
log debug "Checking ReplicaSets:"
REPLICASETS=$(kubectl get rs -n $NAMESPACE | grep $SCOPE_ID)
REPLICASET_COUNT=$(echo "$REPLICASETS" | grep -v "^$" | wc -l)
log debug "$REPLICASETS"
log debug "Found $REPLICASET_COUNT replicaset(s)"
log debug "----------------------------------------"

# Check Pods
log debug "Checking Pods:"
PODS=$(kubectl get pods -n $NAMESPACE | grep $SCOPE_ID)
POD_COUNT=$(echo "$PODS" | grep -v "^$" | wc -l)
log debug "$PODS"
log debug "Found $POD_COUNT pod(s)"
log debug "----------------------------------------"

# Check Ingress
log debug "Checking Ingress:"
INGRESS=$(kubectl get ingress -n $NAMESPACE | grep $SCOPE_ID)
INGRESS_COUNT=$(echo "$INGRESS" | grep -v "^$" | wc -l)
log debug "$INGRESS"
log debug "Found $INGRESS_COUNT ingress(es)"
log debug "----------------------------------------"

# Check Secrets
log debug "Checking Secrets:"
SECRETS=$(kubectl get secrets -n $NAMESPACE | grep $SCOPE_ID)
SECRET_COUNT=$(echo "$SECRETS" | grep -v "^$" | wc -l)
log debug "$SECRETS"
log debug "Found $SECRET_COUNT secret(s)"
log debug "----------------------------------------"

# Summary and Warnings
log debug "SUMMARY:"
if [ $DEPLOYMENT_COUNT -gt 1 ]; then
    log warn "⚠️  WARNING: Multiple deployments found!"
fi
if [ $SERVICE_COUNT -gt 1 ]; then
    log warn "⚠️  WARNING: Multiple services found!"
fi
if [ $INGRESS_COUNT -gt 1 ]; then
    log warn "⚠️  WARNING: Multiple ingresses found!"
fi
if [ $POD_COUNT -gt 1 ]; then
    log warn "⚠️  WARNING: Multiple pods found!"
fi

if [ $DEPLOYMENT_COUNT -eq 1 ] && [ $SERVICE_COUNT -eq 1 ] && [ $INGRESS_COUNT -le 1 ] && [ $POD_COUNT -eq 1 ]; then
    log info "✅ All resources look good! Single instance of each type found."
else
    log error "❌ Some resources need attention. Please check the warnings above."
fi
