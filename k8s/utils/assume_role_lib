#!/bin/bash
# Sourceable library of PURE helpers for assume-role resolution.
#
# Inputs are the AWS IAM provider and scope-configurations provider exactly as
# they appear in CONTEXT.providers[...] — the platform already resolved them for
# the scope's dimensions (most-specific config whose dimensions are a subset of
# the scope's dimensions wins). These helpers only pick the selector / read a
# key, so they make NO np/aws calls and have no side effects on source — fully
# unit-testable.
#
# Requires (at call time): jq.

# arn_for_selector <iam_provider_attributes_json> <selector>
# Given CONTEXT.providers["identity-access-control"], echoes the ARN whose entry
# in .iam_role_arns.arns[] matches <selector>, or "" if none. First match wins.
# Returns "" on empty/malformed input (never crashes).
arn_for_selector() {
  local json="$1" selector="$2"
  [ -n "$json" ] || return 0
  [ -n "$selector" ] || return 0
  printf '%s' "$json" | jq -r --arg sel "$selector" '
    [ .iam_role_arns.arns[]?
      | select(.selector == $sel)
      | .arn ]
    | first // ""' 2>/dev/null
}

# scope_config_assume_role_arn <scope_config_attributes_json>
# Back-compat: .assume_role.arn from CONTEXT.providers["scope-configurations"], or "".
scope_config_assume_role_arn() {
  local json="$1"
  [ -n "$json" ] || return 0
  printf '%s' "$json" | jq -r '.assume_role.arn? // ""' 2>/dev/null
}

# resolve_assume_role_arn <iam_provider_json> <selector> [scope_config_json]
# Full precedence chain. Echoes the ARN to assume ("" = use agent credentials):
#   1. $ASSUME_ROLE_ARN env var (explicit override)
#   2. AWS IAM provider entry matching <selector> (already dimension-resolved
#      by the platform via CONTEXT.providers["identity-access-control"])
#   3. scope-configurations provider assume_role.arn (back-compat)
#   4. $ASSUME_ROLE_ARN_DEFAULT env var (per-account agent default)
# Note: ASSUME_ROLE_ARN="" (explicitly empty) is treated the same as unset —
# the chain continues to the next source. This is intentional and matches the
# upstream scopes-lambda reference behavior.
resolve_assume_role_arn() {
  local iam_json="$1" selector="$2" scope_cfg_json="${3:-}" arn=""

  arn="${ASSUME_ROLE_ARN:-}"

  if [ -z "$arn" ] && [ -n "$iam_json" ] && [ -n "$selector" ]; then
    arn=$(arn_for_selector "$iam_json" "$selector")
  fi

  if [ -z "$arn" ] && [ -n "$scope_cfg_json" ]; then
    arn=$(scope_config_assume_role_arn "$scope_cfg_json")
  fi

  arn="${arn:-${ASSUME_ROLE_ARN_DEFAULT:-}}"
  printf '%s' "$arn"
}
