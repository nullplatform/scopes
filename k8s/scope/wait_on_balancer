#!/bin/bash


log debug "🔍 Waiting for balancer/DNS setup to complete..."

MAX_ITERATIONS=${MAX_ITERATIONS:-30}
iteration=0

case "$DNS_TYPE" in
  external_dns)
    SCOPE_DOMAIN=$(echo "$CONTEXT" | jq -r '.scope.domain')
    SCOPE_SLUG=$(echo "$CONTEXT" | jq -r '.scope.slug')
    SCOPE_ID=$(echo "$CONTEXT" | jq -r '.scope.id')

    DNS_ENDPOINT_NAME="k-8-s-${SCOPE_SLUG}-${SCOPE_ID}-dns"
    log debug "📋 Waiting for ExternalDNS to reconcile DNSEndpoint: $DNS_ENDPOINT_NAME"

    while true; do
        iteration=$((iteration + 1))
        if [ $iteration -gt $MAX_ITERATIONS ]; then
            log error ""
            log error "   ❌ DNSEndpoint reconciliation timeout after $((MAX_ITERATIONS * 10))s"
            log error ""
            log error "💡 Possible causes:"
            log error "   ExternalDNS may still be processing the DNSEndpoint resource"
            log error ""
            log error "🔧 How to fix:"
            log error "   • Check DNSEndpoint resources: kubectl get dnsendpoint $DNS_ENDPOINT_NAME -n $K8S_NAMESPACE -o yaml"
            log error "   • Check ExternalDNS logs: kubectl logs -n external-dns -l app=external-dns --tail=50"
            log error ""
            exit 1
        fi

        log debug "🔍 Checking DNSEndpoint reconciliation (attempt $iteration/$MAX_ITERATIONS)"

        GENERATION=$(kubectl get dnsendpoint "$DNS_ENDPOINT_NAME" -n "$K8S_NAMESPACE" -o jsonpath='{.metadata.generation}' 2>/dev/null || echo "")
        OBSERVED_GENERATION=$(kubectl get dnsendpoint "$DNS_ENDPOINT_NAME" -n "$K8S_NAMESPACE" -o jsonpath='{.status.observedGeneration}' 2>/dev/null || echo "")

        if [ -z "$GENERATION" ]; then
            log debug "📋 DNSEndpoint $DNS_ENDPOINT_NAME not found yet, waiting 10s..."
            sleep 10
            continue
        fi

        log debug "📋 Generation: $GENERATION, ObservedGeneration: $OBSERVED_GENERATION"

        if [ -n "$OBSERVED_GENERATION" ] && [ "$GENERATION" = "$OBSERVED_GENERATION" ]; then
            log info "   ✅ DNSEndpoint $DNS_ENDPOINT_NAME reconciled (generation $GENERATION)"
            log info "   ✅ DNS record for $SCOPE_DOMAIN should now be propagating"
            break
        fi

        log debug "📋 DNSEndpoint not yet reconciled, waiting 10s..."
        sleep 10
    done

    log info ""
    log info "✨ ExternalDNS reconciliation completed successfully"
    ;;
  route53|azure)
    log debug "📋 DNS Type $DNS_TYPE - DNS should already be configured"
    log debug "📋 Skipping DNS wait check"
    ;;
  *)
    log debug "📋 Unknown DNS type: $DNS_TYPE"
    log debug "📋 Skipping DNS wait check"
    ;;
esac
