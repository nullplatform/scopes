#!/bin/bash
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if ! type -t log >/dev/null 2>&1; then source "$SCRIPT_DIR/../../../logging"; fi

log debug "🔍 Building DNS context..."
log debug "📋 DNS type: $DNS_TYPE"

case "$DNS_TYPE" in
  route53)
    source "$SERVICE_PATH/scope/networking/dns/get_hosted_zones"
    ;;
  azure)
    GATEWAY_TYPE="${GATEWAY_TYPE:-istio}"
    export GATEWAY_TYPE

    log debug "📋 Azure DNS configuration:"
    log debug "   Gateway type: $GATEWAY_TYPE"
    log debug "   Hosted zone: $HOSTED_ZONE_NAME (RG: $HOSTED_ZONE_RG)"
    log debug "   Subscription: $AZURE_SUBSCRIPTION_ID"
    log debug "   Resource group: $RESOURCE_GROUP"
    log debug "   Public gateway: $PUBLIC_GATEWAY_NAME"
    log debug "   Private gateway: $PRIVATE_GATEWAY_NAME"
    ;;
  external_dns)
    log debug "📋 DNS records will be managed automatically by External DNS operator"
    ;;
  *)
    log error "❌ Unsupported DNS type: '$DNS_TYPE'"
    log error ""
    log error "💡 Possible causes:"
    log error "   The DNS_TYPE value in values.yaml is not one of: route53, azure, external_dns"
    log error ""
    log error "🔧 How to fix:"
    log error "   • Check DNS_TYPE in values.yaml"
    log error "   • Supported types: route53, azure, external_dns"
    log error ""
    exit 1
    ;;
esac

log info "✅ DNS context ready"
